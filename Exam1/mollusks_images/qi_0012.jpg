           var confirmmessage = "You are being redirected to the PeopleSoft Activate Your Account page.";
           var message = "Action Was Cancelled By User";
           if (confirm(confirmmessage)) {
           window.open ("https://ptprdguest.ctclink.us/psc/ptprdguest/EMPLOYEE/EMPL/c/CTC_FST_USR_LOGIN_MENU.CTC_FST_USR_LOGIN.GBL?");
           } else {
             alert(message);
           }
           };
        </script>
  
