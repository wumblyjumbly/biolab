    if(($.browser.name == 'chrome' && $.browser.versionNumber < 69) || ($.browser.name == 'mozilla' && $.browser.versionNumber < 62) || ($.browser.name == 'safari' && $.browser.versionNumber < 12) || ($.browser.name == 'edge' && $.browser.versionNumber < 71)) 
    { 
          alert("You are on an unsupported browser version. Please update your browser to avoid any login and general ctcLink issues.");
    }
    </script>  

  
  
